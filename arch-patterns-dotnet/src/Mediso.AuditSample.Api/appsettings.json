{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "System.Net.Http.HttpClient": "Warning",
      "Npgsql": "Warning",
      "Marten": "Warning",
      "OpenTelemetry": "Warning"
    }
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Npgsql": "Warning",
        "OpenTelemetry": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties} {NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/audit-api-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {CorrelationId} {TraceId} {SpanId} {Message:lj} {Properties} {NewLine}{Exception}",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithEnvironmentName",
      "WithMachineName",
      "WithThreadId"
    ]
  },
  "Jaeger": {
    "Endpoint": "http://localhost:4318/v1/traces"
  },
  "AllowedHosts": "*",
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "ConnectionStrings": {
    "AuditDb": "Host=localhost;Port=5432;Database=payment_sample;Username=payment_user;Password=8T3BRpPSSlDUSjhXd0PwkRDW00Guwz6maQMYEPHF3FIPD2fFLdlq2g8fipAoHhFL;Search Path=audit_sample"
  },
  "Batching": {
    "IntervalSeconds": 30,
    "MaxItems": 200
  },
  "Anchoring": {
    "IntervalSeconds": 20
  },
  "Solana": {
    "Network": "mainnet-beta",
    "RpcUrl": "https://api.mainnet-beta.solana.com",
    "PrivateKey": "",
    "PublicKey": ""
  }
}
